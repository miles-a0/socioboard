# ==========================================
# Socioboard Environment Variables Example
# ==========================================
# Instructions:
# Copy this file to `.env` and replace the placeholder values (`xxx`) 
# with your actual application credentials.
# Do NOT commit your actual `.env` file to version control!

# --------------------------
# 1. Essential Credentials
# --------------------------
# Used for securely signing JWT tokens and encrypting Vault/Database credentials.
SECRET_KEY=generate_a_random_32-character_key_here
ENCRYPTION_KEY=generate_a_random_32-character_key_for_db_crypto

# --------------------------
# 2. AWS S3 Storage Vaulting
# --------------------------
# Required for uploading cross-platform images and videos dynamically.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=your_socioboard_bucket_name
AWS_REGION=us-east-1

# --------------------------
# 3. OAuth Network Connections
# --------------------------
# Required for authenticating with native platforms for Audience Deployments.
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

PINTEREST_APP_ID=your_pinterest_app_id
PINTEREST_APP_SECRET=your_pinterest_app_secret

SNAPCHAT_CONFIDENTIAL_CLIENT_ID=your_snapchat_confidential_client_id
SNAPCHAT_CLIENT_SECRET=your_snapchat_client_secret

# --------------------------
# 4. Email / Notification
# --------------------------
# Optional: Setup SendGrid API limits for Post Dispatch delivery confirmations.
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_SENDER_EMAIL=your_sender_email@example.com

# --------------------------
# 5. Core Environment Overrides
# --------------------------
# Ngrok URL explicitly needed for handling OAuth callbacks properly on localhost testing.
NGROK_URL=https://your-ngrok-url.ngrok-free.dev
